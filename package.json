{
  "name": "svn-tortoise",
  "version": "1.0.0",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dist": "electron-builder --linux",
    "dist:deb": "electron-builder --linux deb",
    "dist:appimage": "electron-builder --linux AppImage"
  },
  "keywords": [],
  "author": "inineapa",
  "license": "ISC",
  "description": "SVN TortoiseSVN-like desktop app for Ubuntu",
  "build": {
    "appId": "com.inineapa.svn-tortoise",
    "productName": "SVN Tortoise",
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Development",
      "icon": "build/icons"
    },
    "deb": {
      "depends": ["subversion"]
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "src/main/main.js"
    }
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "fast-xml-parser": "^5.5.5",
    "highlight.js": "^11.11.1"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  }
}
